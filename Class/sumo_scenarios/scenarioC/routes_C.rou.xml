<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  routes_C.rou.xml  -  シナリオC（将来計画）
  天神周辺に新たな流入・流出地点を設定
  （都市高速出口候補 + パーキングエリア追加）
  ============================================================
  シナリオBからの変更点:
    ・都市高速出口エッジ（highway_exit）を流入点として追加
    ・パーキングエリアエッジ（parking_area）を流出点として追加
    ・OD-7（天神中心部→その他）の一部がPA行きに変更
    ・都市高速からの流入ルートを新規追加
    
  車両台数（シナリオC: B+約10%増）:
    朝ピーク: 900台  日中: 450台  夕方: 850台
    夜間: 280台  深夜: 90台
    
  OD割合（シナリオC調整）:
    既存OD 1-6: 各-1%削減し、OD-7（PA向け）に充当
    OD-7a (→ PA)       :  8% ← 都市高速利用者・来訪者
    OD-7b (都市高速流入): +8% の新規流入需要
    OD-8  (通過交通)    :  7% 維持
-->

<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

  <!-- ========================================================
       車両タイプ定義（シナリオA/Bに高速流入車を追加）
  ======================================================== -->

  <vType id="car_standard"
         accel="2.6" decel="4.5" sigma="0.5"
         length="4.5" minGap="2.5" maxSpeed="13.89"
         color="0.2,0.6,1.0"
         carFollowModel="Krauss" laneChangeModel="LC2013"
         jmIgnoreKeepClearTime="5"/>

  <vType id="car_commute"
         accel="2.8" decel="4.5" sigma="0.4"
         length="4.5" minGap="2.0" maxSpeed="13.89"
         color="0.1,0.4,0.9"
         carFollowModel="Krauss" laneChangeModel="LC2013"
         jmIgnoreKeepClearTime="3"/>

  <vType id="car_visitor"
         accel="2.0" decel="4.5" sigma="0.6"
         length="4.5" minGap="3.0" maxSpeed="11.11"
         color="0.8,0.5,0.1"
         carFollowModel="Krauss" laneChangeModel="LC2013"/>

  <vType id="van_business"
         accel="2.0" decel="4.0" sigma="0.5"
         length="5.5" minGap="2.5" maxSpeed="11.11"
         color="0.6,0.6,0.6"
         carFollowModel="Krauss" laneChangeModel="LC2013"/>

  <vType id="car_transit"
         accel="2.6" decel="4.5" sigma="0.5"
         length="4.5" minGap="2.5" maxSpeed="13.89"
         color="0.5,0.8,0.5"
         carFollowModel="Krauss" laneChangeModel="LC2013"/>

  <!-- 都市高速流入車（高速道路走行後、減速あり） -->
  <vType id="car_highway"
         accel="2.8" decel="5.0" sigma="0.3"
         length="4.5" minGap="2.5" maxSpeed="13.89"
         color="1.0,0.2,0.2"
         carFollowModel="Krauss" laneChangeModel="LC2013"
         jmIgnoreKeepClearTime="3"/>


  <!-- ========================================================
       ルート定義（シナリオB継承 + 新規追加）
  ======================================================== -->

  <!-- 既存ルート（シナリオBと同一） -->
  <route id="r_watanabe_to_center"
         edges="watanabe_n center_approach tenjin_center"/>

  <route id="r_meiji_to_cityhall"
         edges="meiji_w cityhall_approach tenjin_center"/>

  <route id="r_showa_to_commercial"
         edges="showa_w commercial_approach tenjin_center"/>

  <route id="r_kokutai_to_center"
         edges="kokutai_n center_approach tenjin_center"/>

  <route id="r_center_to_watanabe"
         edges="tenjin_center watanabe_s_approach watanabe_s"/>

  <route id="r_center_to_meiji"
         edges="tenjin_center meiji_e_approach meiji_e"/>

  <route id="r_transit_ns"
         edges="watanabe_n tenjin_center watanabe_s"/>

  <route id="r_transit_ew"
         edges="meiji_w tenjin_center meiji_e"/>

  <!-- 天神通線迂回ルート（シナリオB継承） -->
  <route id="r_detour_via_tenjin_s"
         edges="tenjin_center tenjin_dori_s watanabe_s_south watanabe_s"/>

  <!-- ========================================================
       シナリオC 新規追加ルート
  ======================================================== -->

  <!-- 新規OD-7a: 天神中心部 → パーキングエリア -->
  <route id="r_center_to_parking"
         edges="tenjin_center parking_access parking_area"/>

  <!-- 新規OD-7b: 都市高速出口 → 天神中心部 -->
  <route id="r_highway_to_center"
         edges="highway_exit highway_approach tenjin_center"/>

  <!-- 新規: 都市高速出口 → パーキングエリア（直接） -->
  <route id="r_highway_to_parking"
         edges="highway_exit parking_access parking_area"/>

  <!-- 新規: 都市高速出口 → 渡辺通り方面（通過） -->
  <route id="r_highway_to_watanabe"
         edges="highway_exit highway_approach tenjin_center watanabe_s"/>

  <!-- 新規: パーキングエリア → 天神中心部（出庫後） -->
  <route id="r_parking_to_center"
         edges="parking_area parking_exit tenjin_center"/>

  <!-- 新規: パーキングエリア → 都市高速（帰路） -->
  <route id="r_parking_to_highway"
         edges="parking_area highway_onramp highway_exit"/>

  <!-- 新規: 天神中心部 → 都市高速乗り口（帰路） -->
  <route id="r_center_to_highway"
         edges="tenjin_center highway_onramp highway_exit"/>

  <!-- 天神通線北向き経由（国体道路→中心部） -->
  <route id="r_kokutai_via_tenjin_n"
         edges="kokutai_n tenjin_dori_n tenjin_center"/>


  <!-- ========================================================
       車両フロー — 時間帯別（シナリオC）

       ※ 都市高速関連フローはシナリオCのみ存在
  ======================================================== -->

  <!-- ── 朝ピーク (07:00-09:00) ── 900台 -->
  <!-- OD-1: 900×20% = 180台 → period = 7200/180 = 40.0秒 -->
  <flow id="f_peak_am_od1" type="car_commute" route="r_watanabe_to_center"
        begin="25200" end="32400" period="40.0" departLane="best" departSpeed="max"/>

  <!-- OD-2: 900×15% = 135台 → period = 7200/135 = 53.3秒 -->
  <flow id="f_peak_am_od2" type="car_commute" route="r_meiji_to_cityhall"
        begin="25200" end="32400" period="53.3" departLane="best" departSpeed="max"/>

  <!-- OD-3: 900×15% = 135台 → period = 7200/135 = 53.3秒 -->
  <flow id="f_peak_am_od3" type="car_commute" route="r_showa_to_commercial"
        begin="25200" end="32400" period="53.3" departLane="best" departSpeed="max"/>

  <!-- OD-4: 900×10% = 90台 → period = 7200/90 = 80.0秒 -->
  <flow id="f_peak_am_od4" type="car_commute" route="r_kokutai_to_center"
        begin="25200" end="32400" period="80.0" departLane="best" departSpeed="max"/>

  <!-- OD-5: 900×15% = 135台 → period = 7200/135 = 53.3秒 -->
  <flow id="f_peak_am_od5" type="car_standard" route="r_center_to_watanabe"
        begin="25200" end="32400" period="53.3" departLane="best" departSpeed="max"/>

  <!-- OD-6: 900×10% = 90台 → period = 7200/90 = 80.0秒 -->
  <flow id="f_peak_am_od6" type="van_business" route="r_center_to_meiji"
        begin="25200" end="32400" period="80.0" departLane="best" departSpeed="max"/>

  <!-- OD-7a: 900×8% = 72台 → center→PA → period = 7200/72 = 100.0秒 -->
  <flow id="f_peak_am_od7a" type="car_visitor" route="r_center_to_parking"
        begin="25200" end="32400" period="100.0" departLane="best" departSpeed="max"/>

  <!-- OD-7b: 都市高速流入 900×8% = 72台 → period = 100.0秒 -->
  <flow id="f_peak_am_od7b" type="car_highway" route="r_highway_to_center"
        begin="25200" end="32400" period="100.0" departLane="best" departSpeed="max"/>

  <!-- OD-8: 900×7% = 63台 → period ÷2 = 7200/31.5 = 228.6秒 -->
  <flow id="f_peak_am_od8_ns" type="car_transit" route="r_transit_ns"
        begin="25200" end="32400" period="228.6" departLane="best" departSpeed="max"/>
  <flow id="f_peak_am_od8_ew" type="car_transit" route="r_transit_ew"
        begin="25200" end="32400" period="228.6" departLane="best" departSpeed="max"/>


  <!-- ── 日中オフピーク (09:00-16:00) ── 450台 -->
  <!-- 観光・買い物客中心、都市高速→PA利用増 -->
  <flow id="f_offpeak_od1" type="car_visitor" route="r_watanabe_to_center"
        begin="32400" end="57600" period="280.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od2" type="car_standard" route="r_meiji_to_cityhall"
        begin="32400" end="57600" period="373.3" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od3" type="car_visitor" route="r_showa_to_commercial"
        begin="32400" end="57600" period="373.3" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od4" type="car_standard" route="r_kokutai_to_center"
        begin="32400" end="57600" period="560.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od5" type="car_standard" route="r_center_to_watanabe"
        begin="32400" end="57600" period="373.3" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od6" type="van_business" route="r_center_to_meiji"
        begin="32400" end="57600" period="560.0" departLane="best" departSpeed="max"/>

  <!-- 日中は観光客のPA利用が増加 -->
  <flow id="f_offpeak_od7a" type="car_visitor" route="r_center_to_parking"
        begin="32400" end="57600" period="700.0" departLane="best" departSpeed="max"/>

  <!-- 都市高速→PA直接 -->
  <flow id="f_offpeak_od7b_hw_pa" type="car_highway" route="r_highway_to_parking"
        begin="32400" end="57600" period="700.0" departLane="best" departSpeed="max"/>

  <!-- PA出庫→天神中心部 -->
  <flow id="f_offpeak_od7c_pa_center" type="car_visitor" route="r_parking_to_center"
        begin="32400" end="57600" period="700.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od8_ns" type="car_transit" route="r_transit_ns"
        begin="32400" end="57600" period="800.0" departLane="best" departSpeed="max"/>
  <flow id="f_offpeak_od8_ew" type="car_transit" route="r_transit_ew"
        begin="32400" end="57600" period="800.0" departLane="best" departSpeed="max"/>


  <!-- ── 夕方ピーク (16:00-19:00) ── 850台 -->
  <flow id="f_peak_pm_od1" type="car_standard" route="r_watanabe_to_center"
        begin="57600" end="68400" period="42.4" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od2" type="car_standard" route="r_meiji_to_cityhall"
        begin="57600" end="68400" period="56.5" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od3" type="car_visitor" route="r_showa_to_commercial"
        begin="57600" end="68400" period="56.5" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od4" type="car_standard" route="r_kokutai_to_center"
        begin="57600" end="68400" period="84.7" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od5a" type="car_commute" route="r_center_to_watanabe"
        begin="57600" end="68400" period="56.5" departLane="best" departSpeed="max"/>

  <!-- 夕方帰宅: 天神通線南向き迂回 -->
  <flow id="f_peak_pm_od5b_detour" type="car_commute" route="r_detour_via_tenjin_s"
        begin="57600" end="68400" period="225.9" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od6" type="car_commute" route="r_center_to_meiji"
        begin="57600" end="68400" period="84.7" departLane="best" departSpeed="max"/>

  <!-- 夕方: PA出庫 + 都市高速帰路 -->
  <flow id="f_peak_pm_od7a" type="car_visitor" route="r_center_to_parking"
        begin="57600" end="68400" period="105.9" departLane="best" departSpeed="max"/>
  <flow id="f_peak_pm_od7b_hw" type="car_highway" route="r_highway_to_watanabe"
        begin="57600" end="68400" period="105.9" departLane="best" departSpeed="max"/>
  <!-- PA→都市高速（帰路） -->
  <flow id="f_peak_pm_od7c_pa_hw" type="car_visitor" route="r_parking_to_highway"
        begin="57600" end="68400" period="211.8" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od8_ns" type="car_transit" route="r_transit_ns"
        begin="57600" end="68400" period="242.1" departLane="best" departSpeed="max"/>
  <flow id="f_peak_pm_od8_ew" type="car_transit" route="r_transit_ew"
        begin="57600" end="68400" period="242.1" departLane="best" departSpeed="max"/>


  <!-- ── 夜間 (19:00-22:00) ── 280台 -->
  <flow id="f_night_od1" type="car_standard" route="r_watanabe_to_center"
        begin="68400" end="79200" period="150.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od3" type="car_visitor" route="r_showa_to_commercial"
        begin="68400" end="79200" period="200.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od5" type="car_standard" route="r_center_to_watanabe"
        begin="68400" end="79200" period="150.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od7a_pa" type="car_visitor" route="r_parking_to_center"
        begin="68400" end="79200" period="380.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od8_ns" type="car_transit" route="r_transit_ns"
        begin="68400" end="79200" period="554.3" departLane="best" departSpeed="max"/>


  <!-- ── 深夜 (22:00-翌7:00) ── 90台 -->
  <flow id="f_latenight_a_od5" type="car_standard" route="r_center_to_watanabe"
        begin="79200" end="86400" period="533.3" departLane="best" departSpeed="max"/>

  <flow id="f_latenight_a_od8" type="car_transit" route="r_transit_ns"
        begin="79200" end="86400" period="800.0" departLane="best" departSpeed="max"/>

  <flow id="f_latenight_b_od5" type="car_standard" route="r_center_to_watanabe"
        begin="0" end="25200" period="1600.0" departLane="best" departSpeed="max"/>

  <flow id="f_latenight_b_od8" type="car_transit" route="r_transit_ns"
        begin="0" end="25200" period="2240.0" departLane="best" departSpeed="max"/>

</routes>
