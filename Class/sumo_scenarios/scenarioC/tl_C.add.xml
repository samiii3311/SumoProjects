<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  tl_C.add.xml  -  シナリオC（将来計画）信号制御設定
  都市高速出口・PA追加に対応した信号タイミング
  ============================================================
  シナリオBからの変更点:
    ・都市高速出口合流交差点（tl_highway_exit）を新規追加
    ・PAアクセス道交差点（tl_parking_access）を新規追加
    ・市役所入口: 高速流入による交通量増加を考慮し
                 主方向青時間を45→50秒に延長
    ・天神南: 変更なし
-->

<additional xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/additional_file.xsd">

  <!-- ============================================================
       検知器（シナリオB + 都市高速・PA追加）
  ============================================================ -->

  <laneAreaDetector id="det_watanabe_n"
                    lane="watanabe_n_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_watanabe_n.xml" friendlyPos="true"/>

  <laneAreaDetector id="det_watanabe_s"
                    lane="watanabe_s_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_watanabe_s.xml" friendlyPos="true"/>

  <laneAreaDetector id="det_meiji_e"
                    lane="meiji_e_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_meiji_e.xml" friendlyPos="true"/>

  <laneAreaDetector id="det_showa_w"
                    lane="showa_w_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_showa_w.xml" friendlyPos="true"/>

  <laneAreaDetector id="det_tenjin_dori_n"
                    lane="tenjin_dori_n_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_tenjin_dori_n.xml" friendlyPos="true"/>

  <laneAreaDetector id="det_tenjin_dori_s"
                    lane="tenjin_dori_s_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_tenjin_dori_s.xml" friendlyPos="true"/>

  <!-- シナリオC新規: 都市高速出口検知 -->
  <laneAreaDetector id="det_highway_exit"
                    lane="highway_exit_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_highway_exit.xml" friendlyPos="true"/>

  <!-- シナリオC新規: PAアクセス道検知 -->
  <laneAreaDetector id="det_parking_access"
                    lane="parking_access_0"
                    pos="0" endPos="-1" freq="60"
                    file="output/det_parking_access.xml" friendlyPos="true"/>


  <!-- ============================================================
       信号制御プログラム
  ============================================================ -->

  <!-- 市役所入口交差点 (tl_cityhall)
       シナリオC変更:
         - 高速流入対応で主方向青時間 45→50秒に延長
         - サイクル長: 50+3+12+3+30+3+1 = 102秒
  -->
  <tlLogic id="tl_cityhall" type="static" programID="scenarioC" offset="0">
    <!-- 主方向（渡辺通り + 高速流入合流）青 50秒 -->
    <phase duration="50" state="GGrrrrGGrrrr"/>
    <phase duration="3"  state="yyrrrryyrrrrr"/>
    <!-- 右折フェーズ 12秒 -->
    <phase duration="12" state="rrGrrrrrGrrr"/>
    <phase duration="3"  state="rryrrrrryrrrr"/>
    <!-- 副方向（天神通線双方向）青 30秒 -->
    <phase duration="30" state="rrrrGGrrrrGG"/>
    <phase duration="3"  state="rrrryyrrrryy"/>
    <phase duration="1"  state="rrrrrrrrrrrr"/>
  </tlLogic>

  <!-- 日本銀行前交差点 (tl_boj) - 変更なし -->
  <tlLogic id="tl_boj" type="static" programID="scenarioC" offset="15">
    <phase duration="50" state="GGrrrrGGrrrr"/>
    <phase duration="3"  state="yyrrrryyrrrrr"/>
    <phase duration="10" state="rrGrrrrrGrrr"/>
    <phase duration="3"  state="rryrrrrryrrrr"/>
    <phase duration="35" state="rrrrGGrrrrGG"/>
    <phase duration="3"  state="rrrryyrrrryy"/>
    <phase duration="1"  state="rrrrrrrrrrrr"/>
  </tlLogic>

  <!-- 天神南交差点 (tl_tenjin_south) - シナリオBと変更なし -->
  <tlLogic id="tl_tenjin_south" type="static" programID="scenarioC" offset="30">
    <phase duration="40" state="GGrrrrGGrrrr"/>
    <phase duration="3"  state="yyrrrryyrrrrr"/>
    <phase duration="8"  state="rrGrrrrrGrrr"/>
    <phase duration="3"  state="rryrrrrryrrrr"/>
    <phase duration="32" state="rrrrGGrrrrGG"/>
    <phase duration="3"  state="rrrryyrrrryy"/>
    <phase duration="1"  state="rrrrrrrrrrrr"/>
  </tlLogic>

  <!-- 大丸前交差点 (tl_daimaru) - 変更なし -->
  <tlLogic id="tl_daimaru" type="static" programID="scenarioC" offset="0">
    <phase duration="35" state="GGrrGGrr"/>
    <phase duration="3"  state="yyrryyrr"/>
    <phase duration="25" state="rrGGrrGG"/>
    <phase duration="3"  state="rryyrryy"/>
    <phase duration="4"  state="rrrrrrrr"/>
  </tlLogic>

  <!-- 赤坂交差点（国体道路）(tl_akasaka) - 変更なし -->
  <tlLogic id="tl_akasaka" type="static" programID="scenarioC" offset="45">
    <phase duration="50" state="GGrrrrGGrrrr"/>
    <phase duration="3"  state="yyrrrryyrrrrr"/>
    <phase duration="12" state="rrGrrrrrGrrr"/>
    <phase duration="3"  state="rryrrrrryrrrr"/>
    <phase duration="40" state="rrrrGGrrrrGG"/>
    <phase duration="3"  state="rrrryyrrrryy"/>
    <phase duration="1"  state="rrrrrrrrrrrr"/>
  </tlLogic>

  <!-- ============================================================
       シナリオC 新規追加交差点
  ============================================================ -->

  <!-- 都市高速出口合流交差点 (tl_highway_exit)
       高速道路出口から一般道路への合流部
       サイクル長: 40+3+30+3+1 = 77秒（短めで流入を促進）
  -->
  <tlLogic id="tl_highway_exit" type="static" programID="scenarioC" offset="10">
    <!-- 一般道（主方向）青 40秒 -->
    <phase duration="40" state="GGrrGGrr"/>
    <phase duration="3"  state="yyrryyrr"/>
    <!-- 都市高速出口（副方向・合流）青 30秒 -->
    <phase duration="30" state="rrGGrrGG"/>
    <phase duration="3"  state="rryyrryy"/>
    <!-- 全赤 1秒 -->
    <phase duration="1"  state="rrrrrrrr"/>
  </tlLogic>

  <!-- PAアクセス道交差点 (tl_parking_access)
       パーキングエリア入出口の信号
       サイクル長: 45+3+20+3+1 = 72秒
       ピーク時は感応制御に切り替え（TraCIで実装）
  -->
  <tlLogic id="tl_parking_access" type="static" programID="scenarioC" offset="20">
    <!-- 一般道（主方向）青 45秒 -->
    <phase duration="45" state="GGrrGGrr"/>
    <phase duration="3"  state="yyrryyrr"/>
    <!-- PAアクセス道（副方向）青 20秒 -->
    <phase duration="20" state="rrGGrrGG"/>
    <phase duration="3"  state="rryyrryy"/>
    <!-- 全赤 1秒 -->
    <phase duration="1"  state="rrrrrrrr"/>
  </tlLogic>

</additional>
