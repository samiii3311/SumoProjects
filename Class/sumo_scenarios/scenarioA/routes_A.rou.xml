<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================
  routes_A.rou.xml  -  シナリオA（整備前）
  天神通線（北側）を一方通行に制限したネットワーク
  ============================================================
  車両台数（Excelパラメータ設定ファイルより）:
    朝ピーク   (07:00-09:00) : 800台
    日中       (09:00-16:00) : 400台
    夕方ピーク (16:00-19:00) : 750台
    夜間       (19:00-22:00) : 250台
    深夜       (22:00-07:00) :  80台
  
  OD割合:
    渡辺通り南 → 天神中心部  : 20%
    明治通り東 → 市役所周辺  : 15%
    昭和通り   → 天神商業    : 15%
    国体道路   → 天神中心部  : 10%
    天神中心部 → 渡辺通り南  : 15%
    天神中心部 → 明治通り東  : 10%
    天神中心部 → その他      :  8%  (シナリオAでは通常終端)
    通過交通                 :  7%
-->

<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

  <!-- ========================================================
       車両タイプ定義
  ======================================================== -->

  <!-- 一般乗用車（標準） -->
  <vType id="car_standard"
         accel="2.6" decel="4.5" sigma="0.5"
         length="4.5" minGap="2.5" maxSpeed="13.89"
         color="0.2,0.6,1.0"
         carFollowModel="Krauss"
         laneChangeModel="LC2013"
         jmIgnoreKeepClearTime="5"/>

  <!-- 通勤車両（ラッシュ時挙動：やや積極的） -->
  <vType id="car_commute"
         accel="2.8" decel="4.5" sigma="0.4"
         length="4.5" minGap="2.0" maxSpeed="13.89"
         color="0.1,0.4,0.9"
         carFollowModel="Krauss"
         laneChangeModel="LC2013"
         jmIgnoreKeepClearTime="3"/>

  <!-- 商業・来訪車両（慎重な運転） -->
  <vType id="car_visitor"
         accel="2.0" decel="4.5" sigma="0.6"
         length="4.5" minGap="3.0" maxSpeed="11.11"
         color="0.8,0.5,0.1"
         carFollowModel="Krauss"
         laneChangeModel="LC2013"/>

  <!-- 業務用車両（バン・軽トラ等） -->
  <vType id="van_business"
         accel="2.0" decel="4.0" sigma="0.5"
         length="5.5" minGap="2.5" maxSpeed="11.11"
         color="0.6,0.6,0.6"
         carFollowModel="Krauss"
         laneChangeModel="LC2013"/>

  <!-- 通過交通車両 -->
  <vType id="car_transit"
         accel="2.6" decel="4.5" sigma="0.5"
         length="4.5" minGap="2.5" maxSpeed="13.89"
         color="0.5,0.8,0.5"
         carFollowModel="Krauss"
         laneChangeModel="LC2013"/>


  <!-- ========================================================
       ルート定義（エッジIDはtenjin.net.xmlに合わせて調整）
       ※シナリオA: 天神通線は北向き(tenjin_dori_n)のみ使用可
  ======================================================== -->

  <!-- OD-1: 渡辺通り南 → 天神中心部 (20%) -->
  <route id="r_watanabe_to_center"
         edges="watanabe_n center_approach tenjin_center"/>

  <!-- OD-2: 明治通り東 → 市役所周辺 (15%) -->
  <route id="r_meiji_to_cityhall"
         edges="meiji_w cityhall_approach tenjin_center"/>

  <!-- OD-3: 昭和通り → 天神商業施設 (15%) -->
  <route id="r_showa_to_commercial"
         edges="showa_w commercial_approach tenjin_center"/>

  <!-- OD-4: 国体道路 → 天神中心部 (10%) -->
  <route id="r_kokutai_to_center"
         edges="kokutai_n center_approach tenjin_center"/>

  <!-- OD-5: 天神中心部 → 渡辺通り南 (15%) -->
  <route id="r_center_to_watanabe"
         edges="tenjin_center watanabe_s_approach watanabe_s"/>

  <!-- OD-6: 天神中心部 → 明治通り東 (10%) -->
  <route id="r_center_to_meiji"
         edges="tenjin_center meiji_e_approach meiji_e"/>

  <!-- OD-7: 天神中心部 → その他終端 (8%) ※シナリオAでは通常終端 -->
  <route id="r_center_to_other"
         edges="tenjin_center showa_e"/>

  <!-- OD-8: 通過交通 南北 (3.5%) -->
  <route id="r_transit_ns"
         edges="watanabe_n tenjin_center watanabe_s"/>

  <!-- OD-8: 通過交通 東西 (3.5%) -->
  <route id="r_transit_ew"
         edges="meiji_w tenjin_center meiji_e"/>

  <!-- ========================================================
       車両フロー定義 — 時間帯別 × OD別

       period = 時間帯秒数 / (総台数 × OD割合)
       ※ 負荷分散のためprobabilistic flowを使用
       
       朝ピーク (7:00=25200秒 〜 9:00=32400秒) : 800台
  ======================================================== -->

  <!-- ── 朝ピーク (07:00-09:00) ── -->
  <!-- OD-1: 800台 × 20% = 160台 → period = 7200/160 = 45.0秒 -->
  <flow id="f_peak_am_od1" type="car_commute" route="r_watanabe_to_center"
        begin="25200" end="32400" period="45.0" departLane="best" departSpeed="max"/>

  <!-- OD-2: 800台 × 15% = 120台 → period = 7200/120 = 60.0秒 -->
  <flow id="f_peak_am_od2" type="car_commute" route="r_meiji_to_cityhall"
        begin="25200" end="32400" period="60.0" departLane="best" departSpeed="max"/>

  <!-- OD-3: 800台 × 15% = 120台 → period = 7200/120 = 60.0秒 -->
  <flow id="f_peak_am_od3" type="car_commute" route="r_showa_to_commercial"
        begin="25200" end="32400" period="60.0" departLane="best" departSpeed="max"/>

  <!-- OD-4: 800台 × 10% = 80台 → period = 7200/80 = 90.0秒 -->
  <flow id="f_peak_am_od4" type="car_commute" route="r_kokutai_to_center"
        begin="25200" end="32400" period="90.0" departLane="best" departSpeed="max"/>

  <!-- OD-5: 800台 × 15% = 120台 → period = 7200/120 = 60.0秒 -->
  <flow id="f_peak_am_od5" type="car_standard" route="r_center_to_watanabe"
        begin="25200" end="32400" period="60.0" departLane="best" departSpeed="max"/>

  <!-- OD-6: 800台 × 10% = 80台 → period = 7200/80 = 90.0秒 -->
  <flow id="f_peak_am_od6" type="van_business" route="r_center_to_meiji"
        begin="25200" end="32400" period="90.0" departLane="best" departSpeed="max"/>

  <!-- OD-7: 800台 × 8% = 64台 → period = 7200/64 = 112.5秒 -->
  <flow id="f_peak_am_od7" type="car_visitor" route="r_center_to_other"
        begin="25200" end="32400" period="112.5" departLane="best" departSpeed="max"/>

  <!-- OD-8: 800台 × 7% = 56台 (NS+EW均等) → period = 7200/28 = 257.1秒 -->
  <flow id="f_peak_am_od8_ns" type="car_transit" route="r_transit_ns"
        begin="25200" end="32400" period="257.1" departLane="best" departSpeed="max"/>
  <flow id="f_peak_am_od8_ew" type="car_transit" route="r_transit_ew"
        begin="25200" end="32400" period="257.1" departLane="best" departSpeed="max"/>


  <!-- ── 日中オフピーク (09:00-16:00) ── 400台 -->
  <!-- OD-1: 400台 × 20% = 80台 → period = 25200/80 = 315.0秒 -->
  <flow id="f_offpeak_od1" type="car_visitor" route="r_watanabe_to_center"
        begin="32400" end="57600" period="315.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od2" type="car_standard" route="r_meiji_to_cityhall"
        begin="32400" end="57600" period="420.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od3" type="car_visitor" route="r_showa_to_commercial"
        begin="32400" end="57600" period="420.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od4" type="car_standard" route="r_kokutai_to_center"
        begin="32400" end="57600" period="630.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od5" type="car_standard" route="r_center_to_watanabe"
        begin="32400" end="57600" period="420.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od6" type="van_business" route="r_center_to_meiji"
        begin="32400" end="57600" period="630.0" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od7" type="car_visitor" route="r_center_to_other"
        begin="32400" end="57600" period="787.5" departLane="best" departSpeed="max"/>

  <flow id="f_offpeak_od8_ns" type="car_transit" route="r_transit_ns"
        begin="32400" end="57600" period="900.0" departLane="best" departSpeed="max"/>
  <flow id="f_offpeak_od8_ew" type="car_transit" route="r_transit_ew"
        begin="32400" end="57600" period="900.0" departLane="best" departSpeed="max"/>


  <!-- ── 夕方ピーク (16:00-19:00) ── 750台 -->
  <!-- OD-5（天神→渡辺通り）が支配的になる帰宅パターン -->
  <flow id="f_peak_pm_od1" type="car_standard" route="r_watanabe_to_center"
        begin="57600" end="68400" period="48.0" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od2" type="car_standard" route="r_meiji_to_cityhall"
        begin="57600" end="68400" period="64.0" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od3" type="car_visitor" route="r_showa_to_commercial"
        begin="57600" end="68400" period="64.0" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od4" type="car_standard" route="r_kokutai_to_center"
        begin="57600" end="68400" period="96.0" departLane="best" departSpeed="max"/>

  <!-- 夕方は帰宅（OD-5）が多め -->
  <flow id="f_peak_pm_od5" type="car_commute" route="r_center_to_watanabe"
        begin="57600" end="68400" period="48.0" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od6" type="car_commute" route="r_center_to_meiji"
        begin="57600" end="68400" period="64.0" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od7" type="car_visitor" route="r_center_to_other"
        begin="57600" end="68400" period="120.0" departLane="best" departSpeed="max"/>

  <flow id="f_peak_pm_od8_ns" type="car_transit" route="r_transit_ns"
        begin="57600" end="68400" period="274.3" departLane="best" departSpeed="max"/>
  <flow id="f_peak_pm_od8_ew" type="car_transit" route="r_transit_ew"
        begin="57600" end="68400" period="274.3" departLane="best" departSpeed="max"/>


  <!-- ── 夜間 (19:00-22:00) ── 250台 -->
  <flow id="f_night_od1" type="car_standard" route="r_watanabe_to_center"
        begin="68400" end="79200" period="162.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od3" type="car_visitor" route="r_showa_to_commercial"
        begin="68400" end="79200" period="216.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od5" type="car_standard" route="r_center_to_watanabe"
        begin="68400" end="79200" period="162.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od6" type="car_standard" route="r_center_to_meiji"
        begin="68400" end="79200" period="324.0" departLane="best" departSpeed="max"/>

  <flow id="f_night_od8_ns" type="car_transit" route="r_transit_ns"
        begin="68400" end="79200" period="617.1" departLane="best" departSpeed="max"/>


  <!-- ── 深夜 (22:00-翌7:00) ── 80台 -->
  <!-- 22:00-24:00 (79200-86400) -->
  <flow id="f_latenight_a_od5" type="car_standard" route="r_center_to_watanabe"
        begin="79200" end="86400" period="600.0" departLane="best" departSpeed="max"/>

  <flow id="f_latenight_a_od8" type="car_transit" route="r_transit_ns"
        begin="79200" end="86400" period="900.0" departLane="best" departSpeed="max"/>

  <!-- 翌0:00-7:00 (0-25200) -->
  <flow id="f_latenight_b_od5" type="car_standard" route="r_center_to_watanabe"
        begin="0" end="25200" period="1800.0" departLane="best" departSpeed="max"/>

  <flow id="f_latenight_b_od8" type="car_transit" route="r_transit_ns"
        begin="0" end="25200" period="2520.0" departLane="best" departSpeed="max"/>

</routes>
